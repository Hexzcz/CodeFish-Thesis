# ── Python artifacts ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*

# ── OS / editor junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
node_modules/

# ── Temp / scratch ────────────────────────────────────────────────────────────
cache/
tmp/
/tmp/

# ── Heavy root-level training data (not part of the app) ─────────────────────
/*.pkl
/*.csv
/*.png
/*.tif

# ── Root-level large spatial datasets ────────────────────────────────────────
/ESA_WorldCover_*/
/hotosm_phl_waterways_lines_shp/
/ph137404000_fh*/
/rasters_COP30/
/terrain_features/

# ── Heavy ML / deep learning formats ─────────────────────────────────────────
*.tfrecord
*.h5

# ── ArcGIS / GDAL auxiliary files ────────────────────────────────────────────
*.aux.xml
*.ovr
*.tfw

# ── Untracked scratch / one-off scripts at root (not part of the app) ─────────
/scripts/check_*.py
/scripts/test_*.py
/scripts/apply_*.py
/scripts/debug_*.py

# ── Backend model reports (generated, not source) ────────────────────────────
backend/data/model_reports/

# ─────────────────────────────────────────────────────────────────────────────
# EXPLICIT INCLUSIONS — override the broad *.tif / *.pkl patterns above
# ─────────────────────────────────────────────────────────────────────────────
!backend/data/models/*.pkl
!backend/data/geojson/*.geojson
!backend/data/rasters/*.tif
